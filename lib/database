# 1. Criar banco
DROP DATABASE IF EXISTS AlLibrary;
CREATE DATABASE AlLibrary;
USE AlLibrary;
# 2. Tabela USUARIO
CREATE TABLE usuario (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    tipo ENUM('ALUNO', 'PROFESSOR') NOT NULL
);
# 3. Tabela LIVRO (SEM status ❗)
CREATE TABLE livro (
    id INT AUTO_INCREMENT PRIMARY KEY,
    titulo VARCHAR(150) NOT NULL,
    autor VARCHAR(100),
    ano INT
);
# 4. Tabela EMPRESTIMO
CREATE TABLE emprestimo (
    id INT AUTO_INCREMENT PRIMARY KEY,
    id_usuario INT NOT NULL,
    id_livro INT NOT NULL,
    data_emprestimo DATE NOT NULL,
    data_prevista DATE NOT NULL,
    data_devolucao DATE,

    FOREIGN KEY (id_usuario) REFERENCES usuario(id),
    FOREIGN KEY (id_livro) REFERENCES livro(id)
);
# 5. Índices (performance)
CREATE INDEX idx_livro_titulo ON livro(titulo);
CREATE INDEX idx_emprestimo_livro ON emprestimo(id_livro);
CREATE INDEX idx_emprestimo_usuario ON emprestimo(id_usuario);
# 6. TRIGGER — impedir livro já emprestado
DELIMITER $$

CREATE TRIGGER before_emprestimo_insert
BEFORE INSERT ON emprestimo
FOR EACH ROW
BEGIN
    IF EXISTS (
        SELECT 1 FROM emprestimo
        WHERE id_livro = NEW.id_livro
        AND data_devolucao IS NULL
    ) THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Livro já está emprestado';
    END IF;
END$$

DELIMITER ;
# 7. TRIGGER — limite por usuário
DELIMITER $$

CREATE TRIGGER limite_emprestimo
BEFORE INSERT ON emprestimo
FOR EACH ROW
BEGIN
    DECLARE total INT;
    DECLARE tipo_usuario VARCHAR(20);
    DECLARE limite INT;

    SELECT tipo INTO tipo_usuario
    FROM usuario
    WHERE id = NEW.id_usuario;

    IF tipo_usuario = 'ALUNO' THEN
        SET limite = 3;
    ELSE
        SET limite = 5;
    END IF;

    SELECT COUNT(*) INTO total
    FROM emprestimo
    WHERE id_usuario = NEW.id_usuario
    AND data_devolucao IS NULL;

    IF total >= limite THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Limite de empréstimos atingido';
    END IF;
END$$

DELIMITER ;
# 8. VIEW — livros disponíveis
CREATE VIEW livros_disponiveis AS
SELECT *
FROM livro l
WHERE NOT EXISTS (
    SELECT 1 FROM emprestimo e
    WHERE e.id_livro = l.id
    AND e.data_devolucao IS NULL
);
